rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Auth helpers ────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuth() && request.auth.token.role == 'admin';
    }
    function isLO() {
      return isAuth()
        && request.auth.token.role != 'lender'
        && request.auth.token.role != 'lender_pending'
        && request.auth.token.role != 'admin';
    }
    function isAnyLender() {
      return isAuth() && (
        request.auth.token.role == 'lender' ||
        request.auth.token.role == 'lender_pending'
      );
    }
    // Primary AE for a given NMLS# — must be role:lender with matching nmls claim
    function isPrimaryAEFor(nmls) {
      return isAuth()
        && request.auth.token.role == 'lender'
        && request.auth.token.lenderNmls == nmls;
    }

    // ── Lender Profiles ─────────────────────────────────────────────────────
    // One canonical document per company NMLS# (enforced by Cloud Function).
    // Created only by Cloud Functions (Admin SDK bypasses rules).
    // Deleted by admin from client (paranoid typed-name confirmation) or
    // by Cloud Functions.
    match /lenderProfiles/{profileId} {

      // All authenticated users may read
      allow read: if isAuth();

      // LOs may update ONLY their personal overlay + channel data
      allow update: if isLO()
        && request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['overlays', 'channelOverrides', 'updatedAt']);

      // Primary AE may update everything EXCEPT backupAE and nmls
      allow update: if isPrimaryAEFor(resource.data.nmls)
        && !request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasAny(['backupAE', 'nmls']);

      // Admin may update any field including backupAE (covers edit + archive)
      allow update: if isAdmin();

      // Create: Cloud Functions (Admin SDK) only — deny from client
      allow create: if false;

      // Delete: Admin only (paranoid typed-name confirmation in UI)
      allow delete: if isAdmin();
    }

    // ── Lender Invites ──────────────────────────────────────────────────────
    // Token documents written by LOs, read publicly so the /lender-register
    // page can validate them without auth. Status updates by Cloud Functions.
    match /lenderInvites/{tokenId} {
      allow read: if true;                         // public — token is the secret
      allow create: if isLO();                     // LOs generate invites
      allow update, delete: if isAdmin();          // Cloud Functions update status via Admin SDK
    }

    // ── Lender Intake Prefills ──────────────────────────────────────────────
    // Token documents written by createLenderIntakePrefill Cloud Function
    // when an LO partial-fills the intake form and invites the AE to finish.
    // Public read by token (AE lands on /lender-intake/{token} unauthenticated
    // and the form fetches prefill data to hydrate). Immutable once created.
    // Separate from lenderInvites: this is form-state prefill, not account
    // enrollment. Admin cleanup only.
    match /lenderIntakePrefills/{tokenId} {
      allow read:   if true;                       // public — token is the secret
      allow create: if isLO();                     // LOs generate prefill invites
      allow update: if false;                      // immutable after creation
      allow delete: if isAdmin();                  // admin cleanup only
    }

    // ── Lender Intake Submissions ───────────────────────────────────────────
    // Completed intake forms. Created by anyone (AE with prefill URL, or LO
    // filling the form directly) — unauthenticated access is intentional since
    // the AE may not have a LoanBeacons account yet. Admin reviews and
    // promotes to lenderProfiles (Phase 2). Immutable once submitted.
    match /lenderIntakeSubmissions/{submissionId} {
      allow read:   if isAdmin();                  // admin review only
      allow create: if true;                       // public submit (AE may be unauthed)
      allow update: if isAdmin();                  // admin can change status (pending_review → promoted/rejected)
      allow delete: if isAdmin();
    }

    // ── Lender Accounts ─────────────────────────────────────────────────────
    // Written exclusively by Cloud Functions (Admin SDK). Contains role,
    // lenderNmls, lenderProfileId. Client reads only their own doc.
    match /lenderAccounts/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow write: if false;                       // Cloud Functions only
    }

    // ── Backup AE Requests ──────────────────────────────────────────────────
    // Created when a 2nd AE from the same NMLS# registers (pending approval).
    match /backupAERequests/{requestId} {
      allow read: if isAdmin()
        || (isAuth() && resource.data.uid == request.auth.uid);
      allow create: if isAnyLender();
      allow update, delete: if isAdmin();
    }

    // ── Audit Log ───────────────────────────────────────────────────────────
    // Immutable append-only audit trail for admin actions on lenderProfiles
    // (edit, archive, hard-delete). Each entry records:
    //   uid, email, timestamp, action, targetCollection, targetDocId,
    //   targetName, reason (edit+delete only), before (edit+delete only),
    //   after (edit only).
    // Once written, entries are never modified — compliance/forensics grade.
    match /auditLog/{entryId} {

      // Admin may read the full audit trail
      allow read: if isAdmin();

      // Admin may create entries — but only under their own uid (no forging)
      allow create: if isAdmin()
        && request.resource.data.uid == request.auth.uid;

      // Immutable — no updates, no deletes, ever
      allow update, delete: if false;
    }

    // ── Users (canonical Firebase Auth user doc) ────────────────────────────
    // Stores per-user settings including `acknowledgedTerms` (TOS gate) and
    // `acknowledgedAt`. Each user reads/writes only their own doc.
    // Admin may read any user doc for admin panel purposes.
    match /users/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow write: if isAuth() && request.auth.uid == uid;
    }

    // ── Processor Shares ────────────────────────────────────────────────────
    // HOTFIX 2026-04-23: Added to restore processor share functionality
    // broken by Wave 1 rules deploy (which removed the catch-all that was
    // previously permitting writes to this collection).
    //
    // Architecture note: ProcessorSharePage.jsx reads Firestore directly
    // with an unauthenticated processor. Rule permits public `get` by
    // exact token but denies `list` to prevent enumeration. Unlike AE
    // shares (which route through a Cloud Function), this is direct
    // client-to-Firestore access — hence the narrower `get` permission
    // instead of broad `read`.
    //
    // See Track B follow-up tech debt for consideration of refactoring to
    // Cloud Function HTTP endpoint to mirror the AE share architecture.
    match /processorShares/{shareId} {
      allow get: if true;            // Public read by exact token (token IS the doc ID)
      allow list: if false;          // No enumeration of share IDs
      allow create: if isAuth();     // Authenticated LOs create shares
      allow update, delete: if isAdmin();
    }

    // ── Existing Platform Collections (unchanged) ───────────────────────────
    match /scenarios/{scenarioId} {
      allow read, write: if isAuth();
    }

    match /loProfiles/{profileId} {
      allow read, write: if isAuth();
    }

    match /userProfiles/{profileId} {
      allow read, write: if isAuth();
    }

    match /decisionRecords/{recordId} {
      allow read, write: if isAuth();
    }

    match /dpaPrograms/{uid}/{programId} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    match /platform_activity/{activityId} {
      allow read: if isAdmin();
      allow create: if isAuth();
    }

    match /aeShares/{shareId} {
      allow read, write: if isAuth();
    }
  }
}
